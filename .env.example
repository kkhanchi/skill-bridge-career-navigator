# skill-bridge/.env.example
#
# Copy to `.env` (gitignored) and fill in values. docker compose
# reads `.env` automatically. .env is ignored by git; this template
# is NOT ignored — keep them in sync.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# JWT signing secret. Prod MUST be a long random string (32+
# bytes from a secure source). The dev default below is safe for
# local compose only; leaving it as-is in prod will trigger the
# fail-loud check in ADR-013.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=local-dev-only-please-rotate


# ---------------------------------------------------------------------------
# OPTIONAL — dev-safe defaults supplied by docker-compose.yml
# ---------------------------------------------------------------------------

# Postgres password used by docker-compose. The compose file
# builds DATABASE_URL from this. Change if you want local dev
# credentials that differ from the default.
POSTGRES_PASSWORD=skillbridge-local

# CORS allowlist. "*" is fine for local dev; prod should list
# specific origins (the Streamlit URL, any consumer frontends).
CORS_ORIGINS=*

# Groq API key. Leave empty to use the FallbackCategorizer —
# every test in the suite passes without Groq. Set to a real
# key to exercise the live-LLM path.
GROQ_API_KEY=
