# skill-bridge/.streamlit/secrets.toml.example
#
# Template for Streamlit Cloud deploy secrets. Copy to
# ``.streamlit/secrets.toml`` (gitignored) when developing
# locally and set the real values in the Streamlit Cloud
# dashboard (Settings → Secrets) for production.
#
# Phase 6: the only secret the UI needs is the API base URL.
# Auth tokens live in ``st.session_state`` per-session (no
# persistent storage by design — see ADR-020).

# API_BASE_URL picks which deployed backend the UI talks to.
# Leave uncommented for production; local dev can override via the
# API_BASE_URL env var instead.
#
# API_BASE_URL = "https://skillbridge-api-4foe.onrender.com"
